{
  "$schema": "https://opencode.ai/config.json",

  // Use GPT-5.5 at medium reasoning effort for everyday coding. Increase the
  // reasoning variant per session when a task is unusually difficult.
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "shell": "/bin/zsh",

  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "medium"
          }
        }
      }
    }
  },

  // Keep sessions private; updates are offered but never installed unprompted.
  "share": "disabled",
  "autoupdate": "notify",

  // Enable language-aware edits and automatic formatting where supported.
  "lsp": true,
  "formatter": true,

  // Save filesystem state before edits. This powers OpenCode's undo/revert
  // capabilities; leave it on unless you specifically want less disk usage.
  "snapshot": true,

  // When a conversation approaches the model's context limit, OpenCode
  // summarizes older work rather than losing the entire session.
  "compaction": {
    // Compact automatically instead of interrupting a long task to ask.
    "auto": true,

    // Drop old, already-consumed tool output (large command/test logs) from
    // the conversation after it has been summarized, reducing token use.
    "prune": true,

    // Keep the latest six user turns and their work verbatim after compaction.
    // Increase for more exact recent history; decrease to conserve context.
    "tail_turns": 6
  }
}
